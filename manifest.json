{
  "name": "QR Coder",
  "short_name": "QRCoder",
  "start_url": "./",
  "display": "standalone",
  "background_color": "#fafafa",
  "theme_color": "#f8fafc",
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "file_handlers": [
    {
      "action": "./",
      "accept": {
        "application/json": [".qrcoder", ".qrcoder-theme"],
        "application/octet-stream": [".qrcoder", ".qrcoder-theme"]
      }
    }
  ],
  "share_target": {
    "action": "./",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "shortcuts": [
    {
      "name": "Create Website QR",
      "short_name": "Website",
      "description": "Create a new URL QR code",
      "url": "./?action=create-url",
      "icons": [{ "src": "icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Verify & Scan",
      "short_name": "Scan QR",
      "description": "Open QR Scanner",
      "url": "./?action=scan",
      "icons": [{ "src": "icon-192.png", "sizes": "192x192" }]
    }
  ]
}
